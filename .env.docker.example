# ============================================================
# HRMS Docker Environment Configuration
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your values
#            NEVER commit .env to version control!
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# ── Database (MySQL) ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_DATABASE=hrm_saas
DB_USERNAME=hrms_user
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_PORT_EXPOSE=3306

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT_EXPOSE=6379

# ── Mail (SMTP) ──────────────────────────────────────────────
MAIL_HOST=mail.your-domain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=CHANGE_ME_strong_mail_password
MAIL_FROM_ADDRESS=noreply@your-domain.com

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=CHANGE_ME_random_id
REVERB_APP_KEY=CHANGE_ME_random_key
REVERB_APP_SECRET=CHANGE_ME_random_secret
REVERB_SCHEME=http
REVERB_HOST=0.0.0.0

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=warning

# ── Nginx Proxy Ports ────────────────────────────────────────
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
